# Secrets
.env
.env.local
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store

# Generated reports (keep folder, ignore content)
outputs/*.md
!outputs/.gitkeep

# Cross-branch working-tree leftovers. These directories are owned by
# other branches (release/paper1-representation-gap, experiment/desi-
# generalization-loop-12) and have their own tracking rules there. On
# feature/claim-object-memory they are not part of the feature surface.
data/generalization/
outputs/generalization_loop/
docs/paper1/

# v0.4.1 showcase: per-scenario artefact bundles are regenerable from
# the ShowcaseRunner. The runner code + the top-level README and
# baseline_notes.md are tracked; the bundles themselves are noise
# under git (wall-clock timestamps and per-run UUIDs drift each run).
docs/showcase/S2/
docs/showcase/S6/
docs/showcase/S7/

# v3.124 full-regression scratch files (raw pytest log + start
