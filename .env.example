# DESi configuration
# Copy this file to .env and fill in real values. Never commit .env.

# DeepSeek API
DEEPSEEK_API_KEY=sk-replace-with-your-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Model used by the four non-auditor roles (TRAJECTORY_ANALYST,
# ATTRACTOR_DIAGNOSTICIAN, EN_EVENT_ANALYST, REPORT_SYNTHESIZER).
DEEPSEEK_MODEL=deepseek-v4-flash

# Generation parameters
DESI_TEMPERATURE=0.2
DESI_MAX_TOKENS=2048

# Networking (request-level defaults for the four non-auditor roles)
DESI_TIMEOUT_SECONDS=60
DESI_MAX_RETRIES=3

# Auditor (SKEPTICAL_AUDITOR) role — promoted defaults after paper0
# ablation. Override with `--audit-model flash|pro|auto` on the CLI.
#   flash : deepseek-v4-flash, ~25s/call
#   pro   : deepseek-v4-pro,   ~125s/call (~5x slower)
#   auto  : currently maps to 'pro' (recommended default)
DESI_AUDITOR_MODE=auto
DESI_AUDITOR_TIMEOUT_SECONDS=120
DESI_AUDITOR_MAX_RETRIES=1
