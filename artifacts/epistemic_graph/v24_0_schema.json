    {
      "label": "All trajectories, states and rewards are synthetic fixtures, not collected from a real environment or a trained policy.",
      "node_id": "limitation:L1",
      "node_type": "Limitation"
    },
    {
      "label": "The action space and state space are small, closed and enumerated; they do not approximate a real variable-action ICRL setting at scale.",
      "node_id": "limitation:L2",
      "node_type": "Limitation"
    },
    {
      "label": "Every number is computed by deterministic arithmetic over the fixtures (no PRNG, no learned model), so the values describe the fixtures and not external performance.",
      "node_id": "limitation:L3",
      "node_type": "Limitation"
    },
    {
