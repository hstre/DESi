    {
      "label": "A read-only governance layer reduces redundant search while preserving novel-state reachability.",
      "node_id": "claim:DC1",
      "node_type": "Claim"
    },
    {
      "label": "Capping high-certainty incoherent paths keeps the uncontained hallucination rate at zero under pressure.",
      "node_id": "claim:DC2",
      "node_type": "Claim"
    },
    {
      "label": "A generator/governor split raises distinct-state coverage under sparse-reward-like conditions.",
      "node_id": "claim:DC3",
      "node_type": "Claim"
    },
    {
      "label": "Repetitive loops and dead ends are detected and deprioritised rather than deleted.",
      "node_id": "claim:DC4",
      "node_type": "Claim"
    },
    {
      "label": "The governance layer keeps exploration plural under variable-action-space and non-stationary shifts over a long horizon.",
      "node_id": "claim:DC5",
      "node_type": "Claim"
    },
    {
      "label": "Wild Explorer aggression vs governor conservatism",
      "node_id": "dissent:wild_vs_governor",
      "node_type": "DissentPath"
    },
